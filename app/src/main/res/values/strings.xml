    <string name="notification_title">☔ 降雨提醒</string>
    <!-- Alert message shown in the rain notification.
         %1$s = location name (e.g. "臺北市"), %2$d = threshold percentage (integer).
         %% is the XML / String.format escape for a literal '%' sign; the formatted output
         is e.g. "已超過50%" (one percent sign, not two).
         The format must match NotificationHelper.ALERT_MESSAGE_TEMPLATE so both the
         runtime (context.getString) and unit-test path (buildAlertMessage) produce
         identical output. -->
    <string name="notification_alert_message">您所在的%1$s，目前降雨機率已超過%2$d%%，請多加留意。</string>

