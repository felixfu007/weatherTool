# -----------------------------------------------
# Android / Gradle
# -----------------------------------------------

# Built application files
*.apk
*.aar
*.ap_
*.aab

# Dalvik bytecode
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle build output
.gradle/
build/
app/build/

# Local configuration (SDK paths, signing keys – machine-specific)
local.properties

# IntelliJ / Android Studio project files
*.iml
.idea/
.idea/localHistory/
captures/

# Navigation editor temp files
.navigation/

# External native build
.externalNativeBuild/
.cxx/

# Profiling
*.hprof

# Keystore files (do NOT commit signing keys)
*.jks
*.keystore

# Log files
*.log
logs/

# -----------------------------------------------
# Node / npm (legacy from original .gitignore)
# -----------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
.pnpm-store

# -----------------------------------------------
# Misc
# -----------------------------------------------
.DS_Store
Thumbs.db
